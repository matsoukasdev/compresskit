{
  "version": "0.1.0",
  "name": "loyalty_demo",
  "instructions": [
    {
      "name": "initLoyalty",
      "accounts": [
        { "name": "loyalty", "isMut": true, "isSigner": false, "pda": { "seeds": [{ "kind": "const", "value": "loyalty" }] } },
        { "name": "authority", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "name", "type": "string" }
      ]
    },
    {
      "name": "awardPoints",
      "accounts": [
        { "name": "loyalty", "isMut": true, "isSigner": false },
        { "name": "user", "isMut": false, "isSigner": false },
        { "name": "authority", "isMut": false, "isSigner": true }
      ],
      "args": [
        { "name": "userPubkey", "type": "publicKey" },
        { "name": "points", "type": "u64" }
      ]
    },
    {
      "name": "redeemPoints",
      "accounts": [
        { "name": "loyalty", "isMut": true, "isSigner": false },
        { "name": "user", "isMut": false, "isSigner": true }
      ],
      "args": [
        { "name": "amount", "type": "u64" }
      ]
    }
  ],
  "accounts": [
    {
      "name": "Loyalty",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "authority", "type": "publicKey" },
          { "name": "name", "type": "string" },
          { "name": "totalIssued", "type": "u64" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "UserPoints",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "user", "type": "publicKey" },
          { "name": "balance", "type": "u64" }
        ]
      }
    }
  ],
  "errors": [
    { "code": 6000, "name": "InsufficientBalance", "msg": "user balance below redeem amount" },
    { "code": 6001, "name": "Unauthorized", "msg": "signer is not the loyalty authority" }
  ]
}
